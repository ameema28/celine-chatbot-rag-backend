# Celine Esthetique AI Backend — Environment Template
# Copy this file to .env and fill in your real secrets

# ── LLM Provider ──
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Embeddings ──
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Firebase (Optional — leave blank to use SQLite) ──
FIREBASE_PROJECT_ID=celine-esthetique
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── App Metadata ──
PROJECT_NAME=Celine Esthetique Luxury AI Backend
VERSION=1.0.0
